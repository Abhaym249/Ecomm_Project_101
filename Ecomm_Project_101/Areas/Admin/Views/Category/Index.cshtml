<div class="row">
	<div class="col-9">
		<h2	class="text-danger">Category List</h2>

	</div>
	<div class="col-3">
		<a asp-action="Upsert" class="btn form-control btn-danger">
			<i class="fas fa-plus "></i>&nbsp;Add New Category
		</a>
	</div>
	<div class="container rounded border p-2 m-2">
		<table id="tblData" class="table table-bordered table-striped text-info">
			<thead>
				<tr>
					<th>Edit</th>
					<th>Name</th>
					<th>Delete</th>@*edit,update*@
				</tr>
			</thead>
		</table>
	</div>
</div>
@section Scripts
{
	<script src="~/js/Category.js"></script>
}

