@model Ecomm_Project_101.Models.ViewModels.ProductVM

@{
    var title = Model.Product.Id != 0 ? "Edit Product" : "New Product";
    var saveUpdate = Model.Product.Id != 0 ? "Update" : "Save";
}

<div class="text-primary border-bottom mb-3">
    <h2>@title</h2>
</div>

<div class="row">
    <div class="col-6">
        <form method="post" enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @if (Model.Product.Id != 0)
            {
                <input type="hidden" asp-for="Product.Id" />
            }

            <div class="form-group mb-2">
                <label asp-for="Product.Title"></label>
                <input asp-for="Product.Title" class="form-control" />
                <span asp-validation-for="Product.Title" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.Description"></label>
                <textarea asp-for="Product.Description" class="form-control"></textarea>
                <span asp-validation-for="Product.Description" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.Author"></label>
                <input asp-for="Product.Author" class="form-control" />
                <span asp-validation-for="Product.Author" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.ISBN"></label>
                <input asp-for="Product.ISBN" class="form-control" />
                <span asp-validation-for="Product.ISBN" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.ListPrice"></label>
                <input asp-for="Product.ListPrice" class="form-control" />
                <span asp-validation-for="Product.ListPrice" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.Price"></label>
                <input asp-for="Product.Price" class="form-control" />
                <span asp-validation-for="Product.Price" class="text-danger"></span>
            </div>

            <div class="form-group mb-2">
                <label asp-for="Product.Price50"></label>
                <input asp-for="Product.Price50" class="form-control" />
                <span asp-validation-for="Product.Price50" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Product.Price100"></label>
                <input asp-for="Product.Price100" class="form-control" />
                <span asp-validation-for="Product.Price100" class="text-danger"></span>
            </div>
            <div class="form-group p-2 m-2">
                <label asp-for="Product.ImageUrl"></label>
                <input asp-for="Product.ImageUrl"  type="file" id="UploadImage"
                    class="form-control" />
                <span asp-validation-for="Product.ImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group p-2 m-2">
                <label asp-for="Product.CategoryId"></label>
                <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-control" >
                <option value="">Select value</option>
                </select>
                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
            </div>
            <div class="form-group p-2 m-2">
                <label asp-for="Product.CoverTypeId"></label>
                <select asp-for="Product.CoverTypeId" asp-items="@Model.CoverTypeList" class="form-control" >
                <option value="">Select value</option>
                </select>
                <span asp-validation-for="Product.CoverTypeId" class="text-danger"></span>
            </div>
            <div class="form-group p-2 m-2">
                    @if (Model.Product.Id != 0)
                    {
                        <partial name="_EditAndBackToListButtons" />
                    }
                    else
                    {
                        <div class="row col-10">
                            <div class="col-4 ">
                                <button type="submit" onclick="return ValData()" class="btn btn-info form-control">Save</button>
                            </div>
                       </div>
                       <div class="col-4">
                           <a asp-action="Index" class="btn btn-success form-control">
                               Back To List
                           </a>
                       </div>
                    }
                </div>

            @* <button type="submit" class="btn btn-primary form-control">
                @saveUpdate
            </button> *@

        </form>
    </div>
</div>
@section Scripts{
    <partial name="_ValidationScriptsPartial"></partial>
      
        <script src="https://cdn.tiny.cloud/1/a6t77woi7q9asc5hp58tewin8p7tmvz87ttz7cpsgq7je930/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
         
         function ValData(){
        if (document.getElementById("UploadImage").value==""){
            swal("Error","Please select Product Image !!!",'error');
            return false;}
            return true;}
   
    //**** */
    tinymce.init({
        selector:"textarea",
        plugins:"lists",
        menubar:"file Edit Format"})
    </script>
    }